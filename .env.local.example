# ====================================
# Supabase Configuration
# ====================================
# Get these from: https://app.supabase.com/project/_/settings/api
# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=your-project-url

# Your Supabase anon/public key (safe to use in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Your Supabase service role key (NEVER expose to client, server-only)
# ⚠️ WARNING: This key bypasses Row Level Security - use with caution
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ====================================
# App Configuration
# ====================================
# The URL of your app (used for redirects, OG images, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production URL (use in Vercel environment variables)
# NEXT_PUBLIC_APP_URL=https://killerpool.app
